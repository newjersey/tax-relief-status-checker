{
  "name": "innovation-repo-template",
  "version": "0.3.0",
  "description": "Template repository for the New Jersey State Office of Innovation",
  "repository": "github:newjersey/innovation-repo-template",
  "homepage": "https://github.com/newjersey/innovation-repo-template",
  "bugs": "https://github.com/newjersey/innovation-repo-template/issues",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "keywords": [],
  "author": {
    "name": "New Jersey State Office of Innovation",
    "url": "https://github.com/newjersey"
  },
  "license": "MIT",
  "devDependencies": {
    "husky": "latest",
    "lint-staged": "latest",
    "prettier": "latest",
    "prettier-plugin-jsdoc": "latest",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@newjersey/njwds": "^2.9.1",
    "@trussworks/react-uswds": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-hook-form": "^7.75.0"
  }
}
